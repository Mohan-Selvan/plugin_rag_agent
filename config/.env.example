# API key for whichever LLM provider your config.yaml uses.
# Set just the one(s) you need; leave the rest commented out.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Optional - only when using an OpenAI-compatible endpoint
# (OpenRouter, Together, Groq, etc.) instead of api.openai.com.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional - only when your config uses ollama:* models. Plugin RAG
# does not run Ollama itself; point this at your own Ollama server.
#   Native install:                  http://localhost:11434
#   Docker stack, Ollama on host:    http://host.docker.internal:11434
# OLLAMA_HOST=http://host.docker.internal:11434

# Optional - set true if running behind a reverse proxy that sets
# X-Forwarded-For. The rate limiter will then key on the real client IP.
# TRUST_PROXY=true
